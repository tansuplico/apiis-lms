{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "APIIS LMS",
  "version": "0.3.0",
  "identifier": "com.apiis-lms",
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "APIIS Learning Management System",
        "maximized": true,
        "minWidth": 1024,
        "minHeight": 768
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "createUpdaterArtifacts": true,
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  },
  "plugins": {
    "updater": {
      "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IEZFMzE0RkExNTk5OEFBNkEKUldScXFwaFpvVTh4L29aVG56QjRPNzY5R1VCT3p1UjZhUzM1bkFJeXF0K1g3VmNuS2x1MzRkZnAK",
      "endpoints": [
        "https://github.com/tansuplico/apiis-lms/releases/latest/download/latest.json"
      ],
      "dialog": false
    }
  }
}
